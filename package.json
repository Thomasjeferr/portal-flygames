{
  "name": "portal-futvar",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "prisma generate && next build",
    "start": "next start",
    "lint": "next lint",
    "postinstall": "prisma generate",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:seed-emails": "tsx prisma/seed-emails.ts",
    "cap:sync": "cap sync android",
    "icons:prepare": "node scripts/prepare-icon.js",
    "icons:generate": "npm run icons:prepare && npx capacitor-assets generate --android && npx capacitor-assets generate --pwa && node -e \"const fs=require('fs'); const p='public/icons'; if(!fs.existsSync(p)) fs.mkdirSync(p,{recursive:true}); fs.readdirSync('icons').forEach(f=>fs.copyFileSync('icons/'+f, p+'/'+f));\"",
    "android:build": "node scripts/build-android-apk.js",
    "android:copy-apk": "node scripts/copy-apk.js",
    "android:apk": "npm run android:build && npm run android:copy-apk"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@capacitor/android": "^8.1.0",
    "@capacitor/cli": "^8.1.0",
    "@capacitor/core": "^8.1.0",
    "@prisma/client": "^5.22.0",
    "@stripe/react-stripe-js": "^2.4.0",
    "@stripe/stripe-js": "^2.4.0",
    "@vercel/blob": "^0.26.0",
    "bcryptjs": "^2.4.3",
    "hls.js": "^1.5.8",
    "isomorphic-dompurify": "^3.0.0-rc.2",
    "leaflet": "^1.9.4",
    "next": "15.5.12",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-icons": "^5.6.0",
    "react-leaflet": "^4.2.1",
    "recharts": "^3.7.0",
    "resend": "^6.9.2",
    "stripe": "^20.3.1",
    "tus-js-client": "^4.3.1",
    "uuid": "^10.0.0",
    "video.js": "^8.22.0",
    "videojs-contrib-quality-levels": "^4.1.0",
    "videojs-contrib-quality-menu": "^1.0.4",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/bcryptjs": "^2.4.6",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^22.9.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/uuid": "^10.0.0",
    "autoprefixer": "^10.4.20",
    "dotenv": "^17.3.1",
    "postcss": "^8.4.49",
    "prisma": "^5.22.0",
    "tailwindcss": "^3.4.15",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3"
  }
}
